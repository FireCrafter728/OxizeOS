{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c17",
            "cppStandard": "gnu++17",
            "intelliSenseMode": "linux-gcc-x64",
            "configurationProvider": "ms-vscode.makefile-tools"
        },
        {
            "name": "Watcom",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "_cdecl=",
                "far="
            ],
            "compilerPath": "/usr/bin/watcom/binl/wcc",
            "cStandard": "c99",
            "cppStandard": "c++14",
            "intelliSenseMode": "linux-gcc-x86",
            "compilerArgs": [
                "-4 -d3 -s -wx -ms -zl -zq"
            ]
        },
        {
            "name": "i686-elf-gcc",
            "includePath": [
                "${workspaceFolder}/src/**",
                "${workspaceFolder}/lib/Include"
            ],
            "defines": [],
            "compilerPath": "${workspaceFolder}/toolchain/i686-elf/bin/i686-elf-gcc",
            "cStandard": "c11",
            "cppStandard": "c++11",
            "intelliSenseMode": "linux-gcc-x86",
            "compilerArgs": [
                "-nostdinc++",
                "-ffreestanding",
                "-nostdlib",
                "-m32"
            ]
        },
        {
            "name": "HostTools",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c17",
            "cppStandard": "gnu++17",
            "intelliSenseMode": "linux-gcc-x64",
            "forcedInclude": [
                "${workspaceFolder}/tools/FAT32/global.hpp"
            ]
        }
    ],
    "version": 4
}